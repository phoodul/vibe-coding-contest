# ===========================================
# EduFlow AI - Environment Variables
# ===========================================
# Copy this file to .env and fill in your keys.

# --- Core AI ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# --- Euler Tutor 2.0 ---
# Haiku 4.5 model id for Manager / Critic / Retriever (cost-saving tier)
ANTHROPIC_HAIKU_MODEL_ID=
# Toggle Critic Agent verification (true|false). Default false until A-04 is live.
EULER_CRITIC_ENABLED=
# Manager / Reasoner toggles (default on; set "false" to disable)
EULER_MANAGER_ENABLED=
EULER_REASONER_ENABLED=
EULER_REASONER_MIN_DIFFICULTY=
# Tier-1 candidate auto-report threshold (default 3)
EULER_TOOL_REPORT_THRESHOLD=
# Free user daily start cap (default 10)
EULER_FREE_DAILY_LIMIT=
# Railway SymPy μSvc URL + shared internal token (Phase D)
EULER_SYMPY_URL=
EULER_SYMPY_INTERNAL_TOKEN=
# Phase G-04 — alternating chain & similar_problems RAG 토글
EULER_LEGACY_BACKWARD_ONLY=
EULER_SIMILAR_RAG=

# Phase G-06 — Δ1 5종 quota (베타 한도 + 자격 게이트). 미설정 시 default 사용.
LEGEND_BETA_PROBLEM_TOTAL_DAILY=5
LEGEND_BETA_LEGEND_CALL_DAILY=3
LEGEND_BETA_REPORT_PER_PROBLEM_DAILY=1
LEGEND_BETA_WEEKLY_REPORT_LIMIT=1
LEGEND_BETA_MONTHLY_REPORT_LIMIT=1
LEGEND_WEEKLY_REPORT_PROBLEM_GATE=10
LEGEND_MONTHLY_REPORT_PROBLEM_GATE=20

# Tier 1 라마누잔 — Gemini baseline + Sonnet fallback (G06-30 Δ8)
# 250 RPD 한도 도달 시 페르소나 유지하면서 model_id/provider 만 swap.
LEGEND_RAMANUJAN_MODEL=gemini-3-1-pro
LEGEND_RAMANUJAN_FALLBACK_MODEL=claude-sonnet-4-6-20260101

# Phase G-06 G06-32 (Δ9) — Trial / Beta Access Tier
# 비-베타 (체험판) 사용자 라마누잔 일 3회 한도. (베타는 problem_total_daily 5 사용)
LEGEND_TRIAL_RAMANUJAN_DAILY=3

# G-05 모델 격상: Sonnet 4.5 → 4.6, GPT-5.1 → GPT-5.5
# /api/euler-tutor 채팅 흐름에서 사용. 미설정 시 default 모델 ID 사용.
ANTHROPIC_SONNET_MODEL_ID=claude-sonnet-4-6-20260101
OPENAI_MODEL_ID=gpt-5.5

# --- Toss Payments (Phase D-08) ---
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# --- Supabase (Database / Auth) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# 시드 적재 (scripts/seed-math-tools.ts) + LEG-04 cron 익명화에 필수
SUPABASE_SERVICE_ROLE_KEY=
# LEG-04 cron 인증 (Vercel Cron 자동 발급)
CRON_SECRET=
Supabase_Access_Token=your_supabase_access_token

# --- Math OCR (Euler Tutor) ---
UPSTAGE_API_KEY=your_upstage_api_key
MATHPIX_APP_ID=your_mathpix_app_id
MATHPIX_API_KEY=your_mathpix_api_key

# --- Search (Deep Research) ---
TAVILY_API_KEY=your_tavily_api_key

# --- Book Search (국립중앙도서관 API) ---
Open_API_Key=your_nl_go_kr_api_key

# --- Slide Generation (2Slides) ---
TWOSLIDES_API_KEY=your_2slides_api_key

# --- Image Generation (optional) ---
Replicate_API_token=your_replicate_api_token
