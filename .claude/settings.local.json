{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(mkdir -p \"C:/Users/JSS/vibe-coding-contest/.claude/agents\")",
      "Bash(mkdir -p \"C:/Users/JSS/vibe-coding-contest/templates\")",
      "Bash(mkdir -p \"C:/Users/JSS/vibe-coding-contest/references\")",
      "Bash(npm -v)",
      "Bash(npx create-next-app@latest . --typescript --tailwind --eslint --app --src-dir --no-import-alias --use-npm)",
      "Bash(npm install:*)",
      "Bash(npx tsc:*)",
      "Bash(npm run:*)"
    ]
  },
  "enabledMcpjsonServers": [
    "supabase",
    "playwright",
    "sequential-thinking",
    "context7",
    "firebase",
    "vercel"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/security-guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/env-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/env-guard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-lint.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-lint.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-build-check.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
